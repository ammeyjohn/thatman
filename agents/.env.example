# llama.cpp OpenAI 兼容服务配置
# llama.cpp 启动命令示例:
# ./server -m models/llama-2-7b-chat.gguf --port 8080 --host 0.0.0.0

# OpenAI API 基础 URL (指向 llama.cpp 服务)
OPENAI_API_BASE=http://localhost:8080/v1

# API Key (llama.cpp 默认不需要，但 LangChain 需要设置一个值)
OPENAI_API_KEY=not-needed

# 使用的模型名称 (llama.cpp 会忽略这个值，但需要设置)
OPENAI_MODEL_NAME=llama-2-7b-chat

# Hindsight 记忆服务配置
HINDSIGHT_BASE_URL=http://localhost:8888
# HINDSIGHT_API_KEY=
# 世界 bank 名称，用于存储世界演化相关的长期记忆
HINDSIGHT_WORLD_BANK=world

# 可选：代理设置
# HTTP_PROXY=
# HTTPS_PROXY=
