{
  "skills": [
    {
      "name": "read_doc",
      "description": "读取文档文件内容",
      "module": "skills.read_doc",
      "category": "knowledge",
      "functions": {
        "read_doc": {
          "description": "读取指定文档文件的完整内容",
          "params": {
            "filename": {"type": "string", "description": "文档文件名，如 'world_config.md' 或 '世界观.md'", "required": true}
          },
          "returns": "Dict[str, Any] - 包含 success, filename, title, content, error 的字典"
        },
        "list_available_docs": {
          "description": "列出所有可用的文档文件",
          "params": {},
          "returns": "Dict[str, str] - 文档文件名到标题的映射"
        },
        "search_doc_content": {
          "description": "在所有文档中搜索包含关键词的内容",
          "params": {
            "keyword": {"type": "string", "description": "搜索关键词", "required": true}
          },
          "returns": "Dict[str, Any] - 包含搜索结果的字典"
        }
      }
    },
    {
      "name": "find_skill",
      "description": "查找和列出所有可用的 skills 功能",
      "module": "skills.find_skill",
      "category": "knowledge",
      "functions": {
        "list_all_skills": {
          "description": "列出所有可用的 skills",
          "params": {
            "include_details": {"type": "bool", "description": "是否包含详细信息，默认为 True", "required": false, "default": true}
          },
          "returns": "Dict[str, Any] - 包含所有 skill 信息的字典"
        },
        "search_skill": {
          "description": "根据关键词搜索 skill",
          "params": {
            "keyword": {"type": "string", "description": "搜索关键词", "required": true},
            "search_in_description": {"type": "bool", "description": "是否在描述中搜索，默认为 True", "required": false, "default": true}
          },
          "returns": "Dict[str, Any] - 包含搜索结果的字典"
        },
        "get_skill_info": {
          "description": "获取指定 skill 的详细信息",
          "params": {
            "skill_name": {"type": "string", "description": "skill 名称", "required": true}
          },
          "returns": "Dict[str, Any] - 包含 skill 详细信息的字典"
        }
      }
    },
    {
      "name": "search_episode",
      "description": "根据用户输入和历史聊天内容，从 Qdrant 向量数据库查询相似的小说剧情片段",
      "module": "skills.search_episode",
      "category": "knowledge",
      "functions": {
        "search_similar_episodes": {
          "description": "查询相似的剧情片段",
          "params": {
            "query": {"type": "string", "description": "用户输入的查询文本", "required": true},
            "conversation_history": {"type": "list", "description": "对话历史消息列表", "required": false},
            "top_k": {"type": "int", "description": "返回的相似剧情数量，默认 5", "required": false, "default": 5},
            "collection_name": {"type": "string", "description": "Qdrant 集合名称，默认 episode", "required": false}
          },
          "returns": "Dict[str, Any] - 包含 success, query, total, episodes, error 的字典"
        },
        "format_episodes_as_context": {
          "description": "将搜索结果格式化为 LLM 可用的上下文字符串",
          "params": {
            "search_result": {"type": "dict", "description": "search_similar_episodes 的返回结果", "required": true},
            "max_chars": {"type": "int", "description": "最大字符数限制，默认 2048", "required": false, "default": 2048}
          },
          "returns": "str - 格式化的上下文字符串"
        }
      }
    },
